{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // ─────────────────────────────────────────────────────────────────────────
  // Project-scoped oh-my-openagent config for telemt-mgmt.
  //
  // omo built-in agents + categories are set HERE at project level so omo
  // fully activates project-level mode and discovers .opencode/agents/mentor.md
  // as a primary agent (Tab-cyclable alongside Sisyphus).
  //
  // Pipeline role models (mentor, executor, reviewer, architect-consult,
  // architecture-reviewer) live in .opencode/agents/<role>.md frontmatter,
  // written by `python3 scripts/set-models.py`.
  // ─────────────────────────────────────────────────────────────────────────

  "agents": {
    "sisyphus": {
      "model": "omniroute/SSS-tier",
      "reasoningEffort": "high"
    },
    "hephaestus": {
      "model": "omniroute/SSS-tier"
    },
    "prometheus": {
      "model": "omniroute/SS-tier",
      "reasoningEffort": "high"
    },
    "atlas": {
      "model": "omniroute/A-tier"
    },
    "oracle": {
      "model": "omniroute/SS-tier",
      "reasoningEffort": "high"
    },
    "librarian": {
      "model": "omniroute/A-tier"
    },
    "explore": {
      "model": "omniroute/A-tier"
    },
    "multimodal-looker": {
      "model": "omniroute/SSS-tier"
    },
    "metis": {
      "model": "omniroute/S-tier"
    },
    "momus": {
      "model": "omniroute/SS-tier",
      "reasoningEffort": "high"
    },
    "sisyphus-junior": {
      "model": "omniroute/A-tier"
    }
  },

  "categories": {
    "visual-engineering": {
      "model": "omniroute/SSS-tier"
    },
    "ultrabrain": {
      "model": "omniroute/SS-tier",
      "reasoningEffort": "high"
    },
    "deep": {
      "model": "omniroute/SS-tier",
      "reasoningEffort": "high"
    },
    "quick": {
      "model": "omniroute/B-tier"
    },
    "unspecified-low": {
      "model": "omniroute/A-tier"
    },
    "unspecified-high": {
      "model": "omniroute/SSS-tier",
      "reasoningEffort": "high"
    },
    "writing": {
      "model": "omniroute/SSS-tier"
    },
    "artistry": {
      "model": "omniroute/SSS-tier"
    }
  }
}
