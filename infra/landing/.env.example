# ─────────────────────────────────────────────────────────────────────────────
# Landing page deploy configuration.
# Copy to .env and fill in values, or let deploy-landing.sh prompt you.
# ─────────────────────────────────────────────────────────────────────────────

# Telegram bot URL — the link the "Получить прокси" button points to.
# Format: https://t.me/botname  (replace botname with your actual bot username)
BOT_URL=https://t.me/botname

# Domain for HTTPS (optional).
# If provided, deploy-landing.sh generates an Angie TLS config and
# obtains a Let's Encrypt certificate. If empty, HTTP-only on port 80.
DOMAIN=
