# ─────────────────────────────────────────────────────────────────────────────
# Management server deploy configuration.
# Copy to .env and fill in values, or let deploy-mgmt.sh prompt you.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the telemt REST API on the exit server (e.g. http://exit.example.com:9091).
TELEMT_API_URL=

# Authorization header value for the telemt API (shared secret).
# Must match the AUTH_HEADER configured on the exit server.
TELEMT_AUTH_HEADER=

# Telegram bot token from @BotFather.
BOT_TOKEN=

# SQLAlchemy async database URL.
# If empty, deploy-mgmt.sh auto-creates a PostgreSQL container and sets this.
# Format: postgresql+asyncpg://telemt:PASSWORD@db:5432/telemt
DATABASE_URL=

# Domain name for the admin panel (e.g. panel.example.com).
# Angie serves the panel on :80/:443 with Let's Encrypt TLS.
PANEL_DOMAIN=

# Initial admin username for JWT auth (ADR-002@0.1.0).
ADMIN_USERNAME=

# Initial admin password for JWT auth (bcrypt-hashed on startup).
ADMIN_PASSWORD=

# Salt for sha256(telegram_id + salt)[:16] user ID hashing (INV-HASH).
# Auto-generated if empty. Must be ≥16 chars and never change after initial set.
HASHING_SALT=

# JWT secret key for admin API token signing (HS256, ADR-002@0.1.0).
# Auto-generated if empty.
JWT_SECRET_KEY=

# Entry server FQDN used in tg://proxy links (INV-DOMAIN — domain, never raw IP).
TELEMT_PROXY_SERVER=

# Entry server port for proxy links (e.g. 443).
TELEMT_PROXY_PORT=443

# Comma-separated CORS origins for the admin API (e.g. https://panel.example.com).
# Defaults to the panel domain if empty.
CORS_ORIGINS=
