# ─────────────────────────────────────────────────────────────────────────────
# Monitoring server deploy configuration.
# Copy to .env and fill in values, or let deploy-monitoring.sh prompt you.
# ─────────────────────────────────────────────────────────────────────────────

# Telemt metrics endpoint — the exit server's Prometheus metrics URL.
# Format: IP:9090 (e.g. 10.0.0.5:9090 or proxy.example.com:9090)
# Prometheus scrapes this endpoint for telemt health metrics.
TELEMT_METRICS_ENDPOINT=

# Grafana admin password — used to log in to the Grafana web UI.
# If empty, deploy-monitoring.sh auto-generates a 16-byte hex password.
# Minimum 8 characters recommended.
GRAFANA_ADMIN_PASSWORD=
