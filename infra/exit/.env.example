# ─────────────────────────────────────────────────────────────────────────────
# Exit server deploy configuration.
# Copy to .env and fill in values, or let deploy-exit.sh prompt you.
# .env is gitignored — never commit secrets.
#
# INV-SECRETS: All secrets via env vars only. .env.example documents names.
# ─────────────────────────────────────────────────────────────────────────────

# Domain name of the exit server (e.g. proxy.example.com).
# Used for proxy links and as the mask host domain.
DOMAIN=

# ad_tag — the Telegram ad tag obtained from @MTProxybot.
# Required for channel promotion. Get it via @MTProxybot /newproxy.
# Format: 32-character hex string (e.g. 00112233445566778899aabbccddeeff).
AD_TAG=

# TLS domain for FakeTLS camouflage.
# Default: www.microsoft.com — high-traffic Azure CDN domain with stable TLS 1.3
# characteristics. Changed from github.com per ADR-010@0.2.0 (github.com has an
# ASN mismatch risk that MegaFon has acted on).
# For self-steal mode: enter your own domain with an A-record pointing to this
# server (eliminates ASN mismatch entirely — see ADR-010).
TLS_DOMAIN=www.microsoft.com

# Telemt secret — used as the default user secret for the proxy.
# If empty, deploy-exit.sh auto-generates a 32-byte hex secret.
TELEMT_SECRET=

# Comma-separated list of management server IPs allowed to access
# the telemt API on :9091 (UFW firewall rules).
# Example: 10.0.0.5,203.0.113.10
MANAGEMENT_IPS=

# Comma-separated list of monitoring server IPs allowed to access
# the telemt Prometheus metrics on :9090 (UFW firewall rules).
# Example: 10.0.0.8,198.51.100.20
MONITORING_IPS=

# ── Exit Xray VLESS-Reality (ADR-009@0.2.1) ─────────────────────────────────
# These variables configure the exit server's Xray VLESS-Reality inbound on
# :443, which terminates the encrypted S2 tunnel from the entry server.
# All values are auto-generated by deploy-exit.sh on first run.

# VLESS UUID for the exit server's Xray inbound (AC10).
# Auto-generated by deploy-exit.sh via `xray uuid` or `uuidgen`.
EXIT_VLESS_UUID=

# X25519 private key for the exit server's Reality (AC9).
# Auto-generated by deploy-exit.sh via `xray x25519`.
# WARNING: This is a secret — never share it publicly.
#          The corresponding PUBLIC key is output by deploy-exit.sh for the
#          operator to enter in deploy-entry.sh on the entry server.
EXIT_REALITY_PRIVATE_KEY=

# X25519 public key corresponding to EXIT_REALITY_PRIVATE_KEY.
# Output by deploy-exit.sh for the entry server — the entry's VLESS outbound
# uses this to authenticate to the exit's Reality inbound.
EXIT_REALITY_PUBLIC_KEY=

# SNI for the exit server's Reality (what the tunnel masquerades as).
# Default: www.microsoft.com (same as TLS_DOMAIN for consistency).
# The entry server's EXIT_REALITY_SNI must match this value.
EXIT_REALITY_SNI=www.microsoft.com

# Comma-separated short IDs for the exit server's Reality (client routing).
# Auto-generated by deploy-exit.sh on first run.
# Example: ab12cd34,ef567890
EXIT_REALITY_SHORT_IDS=
