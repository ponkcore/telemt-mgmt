# ─────────────────────────────────────────────────────────────────────────────
# Exit server deploy configuration.
# Copy to .env and fill in values, or let deploy-exit.sh prompt you.
# ─────────────────────────────────────────────────────────────────────────────

# Domain name of the exit server (e.g. proxy.example.com).
# Used for proxy links and as the mask host domain.
DOMAIN=

# ad_tag — the Telegram ad tag obtained from @MTProxybot.
# Required for channel promotion. Get it via @MTProxybot /newproxy.
# Format: 32-character hex string (e.g. 00112233445566778899aabbccddeeff).
AD_TAG=

# TLS domain for FakeTLS camouflage.
# Recommended primary: github.com
# Recommended backup:  www.microsoft.com
TLS_DOMAIN=github.com

# Telemt secret — used as the default user secret for the proxy.
# If empty, deploy-exit.sh auto-generates a 32-byte hex secret.
TELEMT_SECRET=

# Comma-separated list of management server IPs allowed to access
# the telemt API on :9091 (UFW firewall rules).
# Example: 10.0.0.5,203.0.113.10
MANAGEMENT_IPS=

# Comma-separated list of monitoring server IPs allowed to access
# the telemt Prometheus metrics on :9090 (UFW firewall rules).
# Example: 10.0.0.8,198.51.100.20
MONITORING_IPS=
