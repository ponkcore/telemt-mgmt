# .env.example — Entry server (Xray dokodemo-door — transparent TCP forwarder)
#
# Copy to .env and fill in values, or let deploy-entry.sh generate them
# interactively on first run. .env is gitignored — never commit secrets.
#
# INV-SECRETS: All secrets via env vars only. .env.example documents names.
#
# After ADR-009@0.2.1 (TKT-020): the entry server has NO Reality keys, NO VLESS
# UUID, NO SNI of its own. It is a transparent TCP forwarder that injects a
# PROXYv1 header and tunnels to the exit server via VLESS-Reality. All tunnel
# credentials belong to the EXIT server and are generated by deploy-exit.sh.
#
# Run deploy-exit.sh on the exit server FIRST, then copy its output values here.

# EU exit server IP or FQDN (runs telemt + Xray-exit, receives PROXYv1 traffic).
# Example: 185.12.34.56 or exit.example.com
EXIT_SERVER_IP=

# VLESS UUID for the exit server's Xray inbound.
# Generated by deploy-exit.sh on the exit server. Copy the value from its output.
EXIT_VLESS_UUID=

# X25519 public key of the exit server's Reality.
# Generated by deploy-exit.sh on the exit server. Copy the value from its output.
EXIT_PUBLIC_KEY=

# SNI for the exit server's Reality (what the VLESS-Reality tunnel masquerades as).
# Default: ads.x5.ru — a Russian ad CDN domain that blends with normal RU traffic.
EXIT_REALITY_SNI=ads.x5.ru

# Short ID for the exit server's Reality (client routing).
# Generated by deploy-exit.sh on the exit server. Copy the value from its output.
EXIT_SHORT_ID=
