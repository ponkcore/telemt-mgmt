# .env.example — Entry server (Xray VLESS-Reality)
#
# Copy to .env and fill in values, or let deploy-entry.sh generate them
# interactively on first run. .env is gitignored — never commit secrets.
#
# INV-SECRETS: All secrets via env vars only. .env.example documents names.

# EU exit server IP or FQDN (runs telemt, receives PROXYv2 traffic).
# Example: 185.12.34.56 or exit.example.com
EXIT_SERVER_IP=

# Reality SNI — the domain Xray will masquerade as for DPI evasion.
# Recommendations:
#   vkvideo.ru  — RU domestic video CDN (blends with normal RU traffic)
#   yahoo.com   — telemt default (international, low-scrutiny)
REALITY_SNI=yahoo.com

# Reality private key (X25519). Auto-generated by deploy-entry.sh using
# `xray x25519` on first run if not provided.
# WARNING: This is a secret — never share it publicly.
#          The corresponding PUBLIC key goes in client configs.
REALITY_PRIVATE_KEY=

# Reality short IDs — comma-separated hex strings for client routing.
# Auto-generated by deploy-entry.sh on first run if not provided.
# Example: ab12cd34,ef567890
REALITY_SHORT_IDS=
