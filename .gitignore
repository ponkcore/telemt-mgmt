# Secrets — NEVER commit
.env
.env.*
!.env.example
*.pem
*.key
**/secrets/**

# Dependencies / build artifacts (adjust per your stack — see .opencode/project.jsonc)
node_modules/
dist/
build/
coverage/
.cache/
*.log

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp

# opencode runtime state — never committed
.omo/

# NOTE: .opencode/, opencode.json, project.jsonc and docs/ are COMMITTED on
# purpose — they are the pipeline's shared memory (docs-as-code). Do not ignore them.
__pycache__/
.coverage
