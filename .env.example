# ─────────────────────────────────────────────────────────────────────────────
# telemt-mgmt environment variables
#
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All secrets documented per ARCH-001@0.1.2 §9 Secrets Inventory.
# ─────────────────────────────────────────────────────────────────────────────

# telemt API auth header — shared secret for :9091 REST API (C1, C2, C3)
TELEMT_AUTH_HEADER=

# Telegram bot token from @BotFather (C2 standalone bot)
BOT_TOKEN=

# PostgreSQL async connection URL — SQLAlchemy async (C1, C2, C3)
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=

# Salt for SHA256(telegram_id + salt)[:16] user ID hashing (C1)
# Min 16 chars. NEVER change after initial set — breaks existing user lookups.
HASHING_SALT=

# HS256 JWT signing key for admin API auth (C3)
JWT_SECRET_KEY=

# Initial admin setup key — used for first admin account creation (C3)
ADMIN_API_KEY=

# telemt FakeTLS secret — auto-generated by deploy-exit.sh if not provided (C5 exit)
TELEMT_SECRET=

# MTProxy ad_tag from @MTProxybot for channel promotion (C5 exit)
AD_TAG=

# Xray Reality private key — auto-generated by deploy-entry.sh if not provided (C5 entry)
REALITY_PRIVATE_KEY=

# Cloudflare API token with DNS edit permission — used by migrate.sh (C5)
CLOUDFLARE_API_TOKEN=

# Grafana admin password — set via deploy-monitoring.sh (C5 monitoring)
GRAFANA_ADMIN_PASSWORD=
