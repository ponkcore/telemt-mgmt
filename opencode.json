{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md"
  ],
  "permission": {
    "edit": {
      "src/**": "allow",
      "tests/**": "allow",
      "packages/**": "allow",
      "docs/tickets/**": "allow",
      "docs/reviews/**": "allow",
      "docs/questions/**": "allow",
      "docs/backlog/**": "allow",
      "docs/architecture/**": "ask",
      "docs/prd/**": "ask",
      "docs/roadmap/**": "ask",
      "docs/prompts/**": "ask",
      "docs/knowledge/**": "ask",
      "AGENTS.md": "ask",
      "CONTRIBUTING.md": "ask",
      "opencode.json": "ask",
      ".opencode/**": "ask",
      ".github/**": "ask",
      "infra/**": "ask",
      "scripts/**": "ask",
      "Dockerfile": "ask",
      "docker-compose.yml": "ask",
      ".env*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "**/secrets/**": "deny",
      "*": "allow"
    },
    "bash": {
      "rm -rf /*": "deny",
      "rm -rf ~*": "deny",
      "sudo *": "deny",
      "git push --force *": "deny",
      "git push -f *": "deny",
      "git push * --force*": "deny",
      "git push * -f*": "deny",
      "git push origin main*": "deny",
      "git push * main*": "deny",
      "git reset --hard *": "ask",
      "git clean -f*": "ask",
      "git branch -D *": "ask",
      "gh pr merge *--admin*": "ask",
      "git config *": "deny",
      "npm publish*": "deny",
      "docker push *": "deny",
      "*": "allow"
    },
    "external_directory": {
      "{env:HOME}/.local/share/opencode/log/**": "allow",
      "{env:HOME}/.local/share/opencode/snapshot/**": "allow",
      "{env:HOME}/.local/share/opencode/tool-output/**": "allow",
      "/tmp/**": "allow",
      "*": "deny"
    },
    "webfetch": "allow",
    "websearch": "allow"
  }
}
